local function LoadConfig()
    if readfile and isfile and isfile("Tolhub_Data_V6.json") then
        pcall(function()
            local decoded = HttpService:JSONDecode(readfile("Tolhub_Data_V6.json"))
            if decoded.Configs then
                for k, v in pairs(decoded.Configs) do
                    if Configs[k] and k ~= "Air Dribble" then
                        Configs[k].Enabled = v.Enabled
                        Configs[k].Value = v.Value
                    end
                end
            end
            if decoded.GlobalData then
                GlobalData.MaxLimit = decoded.GlobalData.MaxLimit or 15
                GlobalData.LimitEndTime = decoded.GlobalData.LimitEndTime or 0
                GlobalData.CodeUsed = decoded.GlobalData.CodeUsed or false
                GlobalData.AutoSteal = decoded.GlobalData.AutoSteal or false
                GlobalData.SavedAvatarUser = decoded.GlobalData.SavedAvatarUser or ""
            end
        end)
    end
end

