local function ToggleAirDribble(state, size)
    if state then
        if getgenv().AirHelper then getgenv().AirHelper.destroy() end
        
        pcall(function()
            local rs = (cloneref and cloneref(game:GetService("RunService"))) or game:GetService("RunService")
            local tps = workspace:FindFirstChild("TPSSystem") and workspace.TPSSystem:FindFirstChild("TPS")
            
            if not tps then return end
            
            local platform = Instance.new("Part")
            platform.Name = "AirHelper_Tolhub"
            platform.Anchored = true
            platform.CanCollide = true
            platform.Transparency = 1
            platform.CastShadow = false
            platform.Size = Vector3.new(size, 0.1, size)
            platform.Material = Enum.Material.SmoothPlastic
            platform.Parent = workspace.TPSSystem
            platform.CFrame = CFrame.new(tps.Position.X, tps.Position.Y - 1.5, tps.Position.Z)

            local conn
            conn = rs.Heartbeat:Connect(function()
                if tps and tps.Parent then
                    platform.CFrame = CFrame.new(tps.Position.X, tps.Position.Y - 1.5, tps.Position.Z)
                else
                    if getgenv().AirHelper then getgenv().AirHelper.destroy() end
                end
            end)

            getgenv().AirHelper = {
                destroy = function()
                    if conn then conn:Disconnect(); conn = nil end
                    if platform and platform.Parent then platform:Destroy() end
                    getgenv().AirHelper = nil
                end,
                setSize = function(s)
                    if platform and platform.Parent then
                        platform.Size = Vector3.new(s, 0.1, s)
                    end
                end,
            }
        end)
    else
        if getgenv().AirHelper then
            getgenv().AirHelper.destroy()
        end
    end
end

