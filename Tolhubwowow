-- نظام رسم الهيت بوكس المرئي
local function ClearVisuals()
    for _, v in pairs(VisualHitboxes) do
        if v and v.Parent then v:Destroy() end
    end
    table.clear(VisualHitboxes)
end

local function CreateVisualPart(name, color, size, offset)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local part = Instance.new("Part")
    part.Name = name .. "_Visual"
    part.Anchored = false
    part.CanCollide = false
    part.CanTouch = false -- مهم جداً عشان ما يخرب لمس الكرة
    part.CanQuery = false
    part.Massless = true
    part.Material = Enum.Material.ForceField
    part.Color = color
    part.Size = size
    part.CastShadow = false
    
    part.CFrame = root.CFrame * offset
    local weld = Instance.new("WeldConstraint")
    weld.Part0 = root
    weld.Part1 = part
    weld.Parent = part
    part.Parent = char
    table.insert(VisualHitboxes, part)
end

local function UpdateHitboxVisuals()
    ClearVisuals()
    if not ShowHitboxes then return end
    
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    -- رسم Front (أزرق)
    if Configs.Front.Enabled and Configs.Front.Value > 0 then
        local val = Configs.Front.Value
        CreateVisualPart("Front", Color3.new(0, 0.5, 1), Vector3.new(val, 2.5, val), CFrame.new(0, 0, -val/2))
    end
    
    -- رسم Back (أخضر)
    if Configs.Back.Enabled and Configs.Back.Value > 0 then
        local val = Configs.Back.Value
        CreateVisualPart("Back", Color3.new(0, 1, 0.2), Vector3.new(val, 2.5, val), CFrame.new(0, 0, val/2))
    end
    
    -- رسم Side (أحمر) - زوايا فقط زي رسمتك
    if Configs.Side.Enabled and Configs.Side.Value > 0 then
        local val = Configs.Side.Value
        if val > 1.2 then
            local sizeVal = val - 1.2
            local size = Vector3.new(sizeVal, 2.5, sizeVal)
            local offsetDist = 1.2 + (sizeVal / 2)
            CreateVisualPart("Side_FL", Color3.new(1, 0, 0), size, CFrame.new(-offsetDist, 0, -offsetDist))
            CreateVisualPart("Side_FR", Color3.new(1, 0, 0), size, CFrame.new(offsetDist, 0, -offsetDist))
            CreateVisualPart("Side_BL", Color3.new(1, 0, 0), size, CFrame.new(-offsetDist, 0, offsetDist))
            CreateVisualPart("Side_BR", Color3.new(1, 0, 0), size, CFrame.new(offsetDist, 0, offsetDist))
        end
    end
    
    -- رسم Head (أصفر)
    if Configs.Head.Enabled and Configs.Head.Value > 0 then
        local val = Configs.Head.Value
        CreateVisualPart("Head", Color3.new(1, 1, 0), Vector3.new(val, val, val), CFrame.new(0, 2 + val/2, 0))
    end
end

