local function ApplyAvatarLogic(targetName, logFunc)
    task.spawn(function()
        local success, userId = pcall(function() return Players:GetUserIdFromNameAsync(targetName) end)
        if success and userId then
            if logFunc then logFunc("Player found! ID: " .. userId, Color3.fromRGB(0, 255, 120)) end
            task.wait(0.3)
            
            local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
            local hum = char:FindFirstChildOfClass("Humanoid")
            
            if hum then
                pcall(function()
                    if logFunc then logFunc("Removing current avatar...", Color3.fromRGB(255, 170, 0)) end
                    for _, v in pairs(char:GetChildren()) do
                        if v:IsA("Shirt") or v:IsA("Pants") or v:IsA("ShirtGraphic") or v:IsA("Accessory") or v:IsA("Hat") or v.Name == "BypassedAccessory" then
                            v:Destroy()
                        end
                    end
                    task.wait(0.3)
                    
                    local appearance = Players:GetCharacterAppearanceAsync(userId)
                    if appearance then
                        local hasClothes, hasAcc = false, false
                        if logFunc then logFunc("Copying avatar data...", Color3.fromRGB(0, 255, 120)) end
                        task.wait(0.3)

                        for _, item in pairs(appearance:GetChildren()) do
                            if item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") or item:IsA("BodyColors") then
                                item:Clone().Parent = char
                                hasClothes = true
                            elseif item:IsA("Accessory") or item:IsA("Hat") then
                                local cloneAcc = item:Clone()
                                local handle = cloneAcc:FindFirstChild("Handle")
                                if handle then
                                    local accAttachment = handle:FindFirstChildOfClass("Attachment")
                                    local attachmentName = accAttachment and accAttachment.Name or "HatAttachment"
                                    local targetPart, charAttachment
                                    for _, part in pairs(char:GetChildren()) do
                                        if part:IsA("BasePart") then
                                            local att = part:FindFirstChild(attachmentName)
                                            if att then targetPart = part; charAttachment = att; break end
                                        end
                                    end
                                    targetPart = targetPart or char:FindFirstChild("Head")
                                    if targetPart then
                                        handle.CanCollide, handle.Massless = false, true
                                        local weld = Instance.new("Weld")
                                        weld.Name = "AccessoryWeld"
                                        weld.Part0, weld.Part1 = targetPart, handle
                                        if charAttachment and accAttachment then
                                            weld.C0, weld.C1 = charAttachment.CFrame, accAttachment.CFrame
                                        elseif attachmentName == "HatAttachment" then
                                            weld.C0 = CFrame.new(0, 0.5, 0)
                                        end
                                        weld.Parent = handle
                                        handle.Name, handle.Parent = "BypassedAccessory", char
                                        cloneAcc:Destroy()
                                    end
                                else
                                    hum:AddAccessory(cloneAcc)
                                end
                                hasAcc = true
                            end
                        end
                        if logFunc then 
                            if hasClothes then logFunc("Applying clothes...", Color3.fromRGB(0, 255, 120)); task.wait(0.3) end
                            if hasAcc then logFunc("Forcing accessories bypass...", Color3.fromRGB(0, 255, 120)); task.wait(0.3) end
                            logFunc("Operation completed successfully!", Color3.fromRGB(0, 200, 255)) 
                        end
                    else
                        if logFunc then logFunc("Error: Failed to load data.", Color3.fromRGB(255, 50, 50)) end
                    end
                end)
            else
                if logFunc then logFunc("Error: Character not found.", Color3.fromRGB(255, 50, 50)) end
            end
        else
            if logFunc then logFunc("Error: Invalid username.", Color3.fromRGB(255, 50, 50)) end
        end
    end)
end

