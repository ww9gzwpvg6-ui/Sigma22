local function GetPlayerLeg(Char, Hum)
    local Folder = Lighting:FindFirstChild(LocalPlayer.Name)
    local PrefFoot = Folder and Folder:FindFirstChild("PreferredFoot")
    local FootValue = PrefFoot and PrefFoot.Value or 1
    if Hum.RigType == Enum.HumanoidRigType.R6 then
        return (FootValue == 1 and Char:FindFirstChild("Right Leg")) or Char:FindFirstChild("Left Leg")
    else
        return (FootValue == 1 and Char:FindFirstChild("RightLowerLeg")) or Char:FindFirstChild("LeftLowerLeg")
    end
end

RunService.Heartbeat:Connect(function()
    local Character = LocalPlayer.Character
    if not Character then return end
    local Humanoid = Character:FindFirstChildOfClass("Humanoid")
    local RootPart = Character:FindFirstChild("HumanoidRootPart")
    if not Humanoid or not RootPart then return end
    
    local TPSSystem = workspace:FindFirstChild("TPSSystem")
    local Ball = TPSSystem and TPSSystem:FindFirstChild("TPS")
    if not Ball or not Ball:IsA("BasePart") then return end
    
    local TargetLeg = GetPlayerLeg(Character, Humanoid)
    if not TargetLeg then return end
    
    local Distance = (RootPart.Position - Ball.Position).Magnitude
    local ObjectSpace = RootPart.CFrame:PointToObjectSpace(Ball.Position)
    
    local absX = math.abs(ObjectSpace.X)
    local absZ = math.abs(ObjectSpace.Z)
    
    local function FireTouch(direction)
        if (tick() - LastDirectionTicks[direction]) < Cooldowns[direction] then return end
        LastDirectionTicks[direction] = tick()
        
        if Ball.AssemblyLinearVelocity.Magnitude > 5 then
            local Camera = workspace.CurrentCamera
            if Camera then
                local CamLookDir = Camera.CFrame.LookVector
                if direction == "Side" then
                    local SideDir = RootPart.CFrame.RightVector * (ObjectSpace.X > 0 and 1 or -1)
                    Ball.AssemblyLinearVelocity = (Ball.AssemblyLinearVelocity * 0.3) + (CamLookDir * 16) + (SideDir * 5)
                else
                    Ball.AssemblyLinearVelocity = (Ball.AssemblyLinearVelocity * 0.4) + (CamLookDir * 18)
                end
            end
        end
        if firetouchinterest then
            firetouchinterest(TargetLeg, Ball, 0)
            firetouchinterest(TargetLeg, Ball, 1)
        end
    end

    if Configs.Front and Configs.Front.Enabled and Configs.Front.Value > 0 then
        if Distance <= Configs.Front.Value and ObjectSpace.Z < 0 and absX <= absZ then 
            FireTouch("Front") 
        end
    end
    
    if Configs.Side and Configs.Side.Enabled and Configs.Side.Value > 0 then
        if Distance <= Configs.Side.Value and absX >= 1.2 and absZ >= 1.2 then 
            FireTouch("Side") 
        end
    end
    
    if Configs.Back and Configs.Back.Enabled and Configs.Back.Value > 0 then
        if Distance <= Configs.Back.Value and ObjectSpace.Z > 0 and absX <= absZ then 
            FireTouch("Back") 
        end
    end
    
    if Configs.Head and Configs.Head.Enabled and Configs.Head.Value > 0 then
        local HeightDiff = Ball.Position.Y - RootPart.Position.Y
        if Distance <= Configs.Head.Value and HeightDiff > 1 then 
            FireTouch("Head") 
        end
    end
end)
